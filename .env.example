# --- Postgres (pgvector) ---
DATABASE_URL=postgresql://localhost:5432/ragbot

# --- Nebius Token Factory (embeddings, OpenAI-compatible API) ---
NEBIUS_API_KEY=your-nebius-key
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
# Qwen3-Embedding-8B is the embedding model on Nebius. It defaults to 4096 dims;
# we request EMBED_DIM via the `dimensions` param (Matryoshka) so vectors stay
# under pgvector's 2000-dim index limit. 1024 is a good size/quality balance.
EMBED_MODEL=Qwen/Qwen3-Embedding-8B
EMBED_DIM=1024
# Qwen embeddings retrieve better when the QUERY carries a task instruction.
EMBED_QUERY_PREFIX="Instruct: Given a customer support question, retrieve relevant FAQ, manual, or ticket passages. Query: "
EMBED_DOC_PREFIX=

# --- Claude (generation, with citations) ---
ANTHROPIC_API_KEY=your-anthropic-key
GEN_MODEL=claude-sonnet-4-6

# --- Pipeline tuning ---
CHUNK_MAX_TOKENS=512
TOP_K=5
CANDIDATE_K=20
MIN_VSCORE=0.50        # embedding-similarity floor; below this -> escalate to human
STALE_DAYS=30          # support_tickets older than this are dropped

# --- Reranker (cross-encoder, runs locally) ---
# Reorders retrieved context before generation. NOT used for the escalation gate
# (it scores conversational paraphrases unreliably; MIN_VSCORE gates instead).
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_CANDIDATES=20   # how many fused candidates to rerank

# --- Human handoff (email) ---
ESCALATION_EMAIL=vinisha6789@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-app-password
EMAIL_FROM=your-smtp-user
